# Admin Panel Credentials
REACT_APP_ADMIN_USERNAME="admin"
REACT_APP_ADMIN_PASSWORD="icc@2026"

# Contact Information
REACT_APP_SALES_PHONE="+91-9365375782"
REACT_APP_WHATSAPP_NUMBER="+919365375782"
REACT_APP_SALES_EMAIL="iconcom.2004@gmail.com"
REACT_APP_SUPPORT_EMAIL="iconcom.2004@gmail.com"

# Office Address
REACT_APP_OFFICE_ADDRESS="Rajgarh Road, Near Byelane No-3, Chandmari, Guwahati, Assam – 781003"

# Social Media Links (optional)
REACT_APP_FACEBOOK_URL=""
REACT_APP_INSTAGRAM_URL=""
REACT_APP_YOUTUBE_URL=""
REACT_APP_LINKEDIN_URL=""

# Google Maps Configuration
REACT_APP_GOOGLE_MAPS_API_KEY=""
REACT_APP_PROJECT_LATITUDE="0.0000"
REACT_APP_PROJECT_LONGITUDE="0.0000"

# Analytics & Tracking (optional — GTM only; leave blank to disable)
REACT_APP_GTM_ID=""
REACT_APP_ENABLE_ANALYTICS=false

# Lead Storage (shared server-side store — single source of truth)
# REACT_APP_LEADS_ADMIN_KEY MUST match the admin key the PHP API resolves
# (public/api/leads.php / notices.php / events.php) — which defaults to the
# committed value below when no config.php / env override is set. The admin
# panel sends this as X-Admin-Key to list/create/update/delete leads, notices
# and events; a mismatch returns 401 and silently breaks all admin writes.
REACT_APP_LEADS_API_URL="/api/leads.php"
REACT_APP_LEADS_ADMIN_KEY="skdfjsdfweiormcnzxmzdlkfjds"

# Notices & Events stores (same cross-device sync pattern as leads)
REACT_APP_NOTICES_API_URL="/api/notices.php"
REACT_APP_EVENTS_API_URL="/api/events.php"

# Hero Video (set URL to enable hero background video)
REACT_APP_HERO_VIDEO_URL=""

# ============================================
# Leads are stored server-side via /api/leads.php (the single source of truth).
# The admin panel reads/writes leads there so every browser/device stays in
# sync. REACT_APP_LEADS_API_URL + REACT_APP_LEADS_ADMIN_KEY (above) configure it
# (the key must match ADMIN_API_KEY in public/api/config.php).
# ============================================
